# GitHub Copilot Prompt:
# Filter the panel to pre-treatment years. Plot mean employment by year for
# each group to visually check parallelism. Then run OLS:
# employment ~ year_c * TREATED with HC3 standard errors on the pre-period
# sample. An insignificant interaction term supports parallel trends.

pre_panel = long_panel[long_panel["year"] < POLICY_YEAR].copy()
pre_panel["year_c"] = pre_panel["year"] - pre_panel["year"].min()

mean_pre = (
    pre_panel.groupby(["year", "TREATED"])["employment"]
    .mean()
    .reset_index()
)
pivot_pre = mean_pre.pivot(index="year", columns="TREATED", values="employment")
pivot_pre.columns = ["Control", "Treated"]

fig, ax = plt.subplots(figsize=(10, 6))
ax.plot(pivot_pre.index, pivot_pre["Treated"], marker="o", color="blue", label="Treated")
ax.plot(pivot_pre.index, pivot_pre["Control"], marker="s", color="red", label="Control")
