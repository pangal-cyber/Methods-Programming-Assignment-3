ax.set_ylabel("Mean Employment")
ax.yaxis.set_major_formatter(mticker.StrMethodFormatter("{x:,.0f}"))
ax.legend()
plt.savefig("pretrend_plot.png", dpi=150)
plt.close()

robust_results = smf.ols("employment ~ year_c * TREATED", data=pre_panel).fit(cov_type="HC3")

print(robust_results.summary())
print(
    "Pre-treatment interaction coefficient:",
    robust_results.params.get("year_c:TREATED", robust_results.params.get("TREATED:year_c")),
    "p=",
