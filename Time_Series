# GitHub Copilot Prompt:
# Write a function that takes a brief URL, fetches the page, finds the
# employment <table>, extracts year columns (2018-2025) and the bold county
# name from each REGION cell using BeautifulSoup, and returns a tidy
# DataFrame with columns: region_raw, 2018..2025, source_url.
def scrape_brief(url):
    response = requests.get(url)
    response.raise_for_status()
    soup = BeautifulSoup(response.text, "html.parser")
    
    # Find the employment table (assuming it's the table containing employment data)
    table = soup.find('table')
    if not table:
        return pd.DataFrame()
    
    all_rows = table.find_all('tr')
    
    # FIX 1: Row 0 has empty <th> cells — the real column names are in row 1.
    # Scan for whichever row contains "REGION" to be safe.
    header_idx = None
    for i, tr in enumerate(all_rows):
        cells_text = [td.get_text(strip=True) for td in tr.find_all(['th', 'td'])]
        if 'REGION' in cells_text:
            headers = cells_text
            header_idx = i
            break
    
    if header_idx is None:
        return pd.DataFrame()
    
    data = []
    # FIX 3: Data rows start after the header row, not after row 0.
    for row in all_rows[header_idx + 1:]:
        cells = row.find_all('td')
        if len(cells) < 2:
            continue
        
        # FIX 2: County names use <strong>, not <b>.
        region_cell = cells[0]
        bold = region_cell.find('strong') or region_cell.find('b')
        region_raw = bold.get_text(strip=True) if bold else region_cell.get_text(strip=True)
        
        row_data = {'region_raw': region_raw, 'source_url': url}
        
        for header, cell in zip(headers[1:], cells[1:]):
            if header.isdigit() and 2018 <= int(header) <= 2025:
                row_data[header] = cell.get_text(strip=True)
        
        data.append(row_data)
    
    return pd.DataFrame(data)
# GitHub Copilot Prompt:
# Loop over brief_links, call scrape_brief() on each URL, collect non-empty
# DataFrames in a list, concatenate into one raw panel, and save to
# raw_employment.csv.
dfs = []
for url in brief_links:
    df = scrape_brief(url)
    if not df.empty:
        dfs.append(df)

raw_panel = pd.concat(dfs, ignore_index=True)
raw_panel.to_csv('raw_employment.csv', index=False)

# stage 2 Clean the data
def clean_employment(s):
    if pd.isna(s) or s == '':
        return np.nan
    # Strip tildes and commas
    s = s.replace('~', '').replace(',', '')
    # Remove 'jobs' if present
    s = s.replace('jobs', '').strip()
    # Check for suffixes
    if 'thousand' in s.lower():
        s = s.lower().replace('thousand', '').strip()
        return int(float(s) * 1000)
    elif 'k' in s.lower():
        s = s.lower().replace('k', '').strip()
        return int(float(s) * 1000)
    else:
        return int(float(s))

